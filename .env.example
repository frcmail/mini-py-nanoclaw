# Core runtime
NANOCLAW_HOME=~/.nanoclaw
ASSISTANT_NAME=Andy
LOG_LEVEL=INFO

# Channels (comma-separated)
NANOCLAW_CHANNELS=local-file

# Webhook channel (required only when webhook-http is enabled)
NANOCLAW_WEBHOOK_HOST=127.0.0.1
NANOCLAW_WEBHOOK_PORT=8787
NANOCLAW_WEBHOOK_TOKEN=
NANOCLAW_WEBHOOK_OUTBOUND_URL=

# Optional container tuning
CONTAINER_TIMEOUT=1800000
MAX_CONCURRENT_CONTAINERS=5
NANOCLAW_REQUIRE_CONTAINER_RUNTIME=0
